     <widget class="QSlider" name="sliderCortes">
      <property name="geometry">
       <rect>
        <x>300</x>
        <y>610</y>
        <width>281</width>
        <height>41</height>
       </rect>
      </property>
      <property name="styleSheet">
       <string notr="true">/* La barra de fondo por donde se desliza */
QSlider::groove:horizontal {
    border: none;
    height: 6px;
    background: #E0E0E0;
    border-radius: 3px;
}

/* El botón redondo que arrastras */
QSlider::handle:horizontal {
    background: #14B87A; /* El verde brillante de Vitalis */
    border: none;
    width: 16px;
    height: 16px;
    margin: -5px 0; /* Lo centra perfectamente sobre la barra */
    border-radius: 8px; /* Lo hace completamente redondo */
}

/* Cambia de color cuando el médico pasa el mouse por encima del botón */
QSlider::handle:horizontal:hover {
    background: #0F766E; /* El verde oscuro del Sidebar */
    background-color: qradialgradient(cx:0.5, cy:0.5, radius:0.5, fx:0.5, fy:0.5, stop:0 #14B87A, stop:1 #0F766E);
}

/* La barra que se va llenando a la izquierda del botón */
QSlider::sub-page:horizontal {
    background: #7DCAA6; /* Un verde más suave para el progreso */
    border-radius: 3px;
}</string>
      </property>
      <property name="orientation">
       <enum>Qt::Horizontal</enum>
