  <property name="styleSheet">
   <string notr="true">
#centralwidget { background-color: #F4F8F6; }
#sidebar { background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #0F766E, stop:1 #14B87A); }
#labelLogoSidebar { color: #FFFFFF; }
#sidebar QPushButton { background-color: rgba(255,255,255,40); color:#FFFFFF; border:none; border-radius:10px; text-align:left; padding-left:15px; font-size:14px; }
#sidebar QPushButton:hover { background-color: rgba(255,255,255,80); }
#btnCerrarSesion { background-color: rgba(255,255,255,25); }
#btnCerrarSesion:hover { background-color: rgba(220,80,80,160); }
#labelBienvenidaUsuario, #labelTituloUsuarios, #labelDicomInfo, #labelSenalesInfo, #labelDatosInfo { color: #0F766E; }
#cardImagenes, #cardSenales, #cardDatos, #cardPrincipal, #cardForm, #cardTabla { background-color: #FFFFFF; border-radius: 15px; }
#labelCardImg, #labelCardSen, #labelCardDat, #labelAreaTitulo, #labelFormTitulo, #labelTablaTitulo { color: #0F766E; }
#labelAreaGeneral { border: 3px dashed #7DCAA6; border-radius:12px; background:#F9FFFC; color:#0F766E; }
QLineEdit, QComboBox { border:1px solid #cccccc; border-radius:8px; padding:6px; background:#FFFFFF; }
QLineEdit:focus { border:1px solid #14B87A; }
#btnCrearUsuario, #btnRefrescarUsuarios, #btnCargarDicom, #btnCargarSenal, #btnCargarTabla,
#btnExportarCSV, #btnNifti, #btnAplicarZoom, #btnGuardarRecorte, #btnSegmentar,
#btnGraficarCanal, #btnAgregarRuido, #btnEstadisticas3D, #btnGraficarColumnas, #btnGraficarScatter { background-color: #14B87A; color:#FFFFFF; border:none; border-radius:8px; font-weight:bold; }
#btnCrearUsuario:hover, #btnRefrescarUsuarios:hover, #btnCargarDicom:hover, #btnCargarSenal:hover,
#btnCargarTabla:hover, #btnExportarCSV:hover, #btnNifti:hover, #btnAplicarZoom:hover,
#btnGuardarRecorte:hover, #btnSegmentar:hover, #btnGraficarCanal:hover, #btnAgregarRuido:hover,
#btnEstadisticas3D:hover, #btnGraficarColumnas:hover, #btnGraficarScatter:hover { background-color: #0F766E; }
QTableWidget { border:1px solid #E0E0E0; border-radius:8px; background:#FFFFFF; }
QHeaderView::section { background-color:#DFF7EE; color:#0F766E; padding:6px; border:none; font-weight:bold; }
QGroupBox { border:1px solid #7DCAA6; border-radius:8px; margin-top:6px; color:#0F766E; font-weight:bold; }
QGroupBox::title { subcontrol-origin:margin; left:10px; padding:0 4px; }
QSlider::groove:horizontal { border:none; height:6px; background:#E0E0E0; border-radius:3px; }
QSlider::handle:horizontal { background:#14B87A; border:none; width:16px; height:16px; margin:-5px 0; border-radius:8px; }
QSlider::handle:horizontal:hover { background:#0F766E; }
QSlider::sub-page:horizontal { background:#7DCAA6; border-radius:3px; }
QRadioButton { color:#0F766E; font-weight:bold; }
QSpinBox { border:1px solid #cccccc; border-radius:8px; padding:4px; background:#FFFFFF; }
   </string>
  </property>
